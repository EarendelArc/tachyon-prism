    },
    "devDependencies": {
        "@tauri-apps/cli": "2.11.2",
        "@types/node": "^25.9.3",
        "@types/react": "19.2.16",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "6.0.2",
        "typescript": "6.0.3",
        "vite": "8.0.16",
        "vitest": "^4.1.8"
    }
}
